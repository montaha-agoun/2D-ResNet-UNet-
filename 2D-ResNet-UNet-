    "# ── Cell 8: ResNet-UNet architecture ─────────────────────────────────────────\n",
    "#\n",
    "# Encoder : ResNet-34 pretrained on ImageNet\n",
    "#   skip connections taken from 4 ResNet stages:\n",
    "#     layer1 → 64ch  (H/4)\n",
    "#     layer2 → 128ch (H/8)\n",
    "#     layer3 → 256ch (H/16)\n",
    "#     layer4 → 512ch (H/32)\n",
    "# Bottleneck: after layer4, one extra DoubleConv (1024ch, H/32)\n",
    "# Decoder : 4× upsampling blocks that concatenate encoder skips\n",
    "#\n",
    "\n",
    "class DecoderBlock(nn.Module):\n",
    "    \"\"\"Upsample → concat skip → DoubleConv.\"\"\"\n",
    "    def __init__(self, in_ch, skip_ch, out_ch):\n",
    "        super().__init__()\n",
    "        self.up = nn.ConvTranspose2d(in_ch, in_ch // 2, kernel_size=2, stride=2)\n",
    "        self.conv = nn.Sequential(\n",
    "            nn.Conv2d(in_ch // 2 + skip_ch, out_ch, 3, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(out_ch), nn.ReLU(inplace=True),\n",
    "            nn.Conv2d(out_ch, out_ch, 3, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(out_ch), nn.ReLU(inplace=True),\n",
    "        )\n",
    "\n",
    "    def forward(self, x, skip):\n",
    "        x = self.up(x)\n",
    "        # If the upsampled x is not the same size as skip, adjust skip\n",
    "        # This ensures the decoder path maintains or increases resolution\n",
    "        if x.shape[2:] != skip.shape[2:]:\n",
    "            skip = torch.nn.functional.interpolate(skip, size=x.shape[2:], mode='bilinear', align_corners=False)\n",
    "        x = torch.cat([x, skip], dim=1)\n",
    "        return self.conv(x)\n",
    "\n",
    "\n",
    "class ResUNet(nn.Module):\n",
    "    \"\"\"\n",
    "    U-Net with a pretrained ResNet-34 encoder.\n",
    "    Input : (B, 3, H, W)  — RGB, any multiple of 32\n",
    "    Output: (B, 1, H, W)  — raw logits\n",
    "    \"\"\"\n",
    "    def __init__(self, n_classes=1, pretrained=True):\n",
    "        super().__init__()\n",
    "        self.n_classes = n_classes\n",
    "        # ── Encoder ──────────────────────────────────────────────────────────\n",
    "        backbone = models.resnet34(weights='IMAGENET1K_V1' if pretrained else None)\n",
    "\n",
    "        # stem: Conv + BN + ReLU  (stride 2 → H/2, 64ch)\n",
    "        self.enc0 = nn.Sequential(\n",
    "            backbone.conv1, backbone.bn1, backbone.relu\n",
    "        )  # out: 64ch, H/2\n",
    "        self.pool  = backbone.maxpool          # H/4\n",
    "        self.enc1  = backbone.layer1           # 64ch,  H/4\n",
    "        self.enc2  = backbone.layer2           # 128ch, H/8\n",
    "        self.enc3  = backbone.layer3           # 256ch, H/16\n",
    "        self.enc4  = backbone.layer4           # 512ch, H/32\n",
    "\n",
    "        # ── Bottleneck ───────────────────────────────────────────────────────\n",
    "        self.bottleneck = nn.Sequential(\n",
    "            nn.Conv2d(512, 1024, 3, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(1024), nn.ReLU(inplace=True),\n",
    "            nn.Conv2d(1024, 1024, 3, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(1024), nn.ReLU(inplace=True),\n",
    "        )  # 1024ch, H/32\n",
    "\n",
    "        # ── Decoder ──────────────────────────────────────────────────────────\n",
    "        # Each DecoderBlock(in_ch, skip_ch, out_ch)\n",
    "        self.dec4 = DecoderBlock(1024, 512, 512)   # H/16\n",
    "        self.dec3 = DecoderBlock(512,  256, 256)   # H/8\n",
    "        self.dec2 = DecoderBlock(256,  128, 128)   # H/4\n",
    "        self.dec1 = DecoderBlock(128,   64,  64)   # H/2  (skip from enc1)\n",
    "        # Final up to full resolution (no skip — use enc0 stem features)\n",
    "        self.dec0 = DecoderBlock(64,    64,  32)   # H\n",
    "\n",
    "        self.final = nn.Conv2d(32, 1, kernel_size=1)\n",
    "\n",
    "        #deepsupervision\n",
    "        self.ds4 = nn.Conv2d(256, self.n_classes, kernel_size=1) # High-level\n",
    "        self.ds3 = nn.Conv2d(128, self.n_classes, kernel_size=1)\n",
    "        self.ds2 = nn.Conv2d(64, self.n_classes, kernel_size=1)\n",
    "        self.ds1 = nn.Conv2d(32, self.n_classes, kernel_size=1) # Final output\n",
    "\n",
    "    def forward(self, x):\n",
    "        # Encoder\n",
    "        e0 = self.enc0(x)          # 64ch,  H/2\n",
    "        e1 = self.enc1(self.pool(e0))  # 64ch,  H/4\n",
    "        e2 = self.enc2(e1)         # 128ch, H/8\n",
    "        e3 = self.enc3(e2)         # 256ch, H/16\n",
    "        e4 = self.enc4(e3)         # 512ch, H/32\n",
    "\n",
    "        # Bottleneck\n",
    "        b  = self.bottleneck(e4)   # 1024ch, H/32\n",
    "\n",
    "        # Decoder\n",
    "        d4 = self.dec4(b,  e4)     # 512ch, H/16\n",
    "        d3 = self.dec3(d4, e3)     # 256ch, H/8\n",
    "        d2 = self.dec2(d3, e2)     # 128ch, H/4\n",
    "        d1 = self.dec1(d2, e1)     # 64ch,  H/2\n",
    "        d0 = self.dec0(d1, e0)     # 32ch,  H\n",
    "\n",
    "        return self.final(d0)      # 1ch,   H\n",
    "\n",
    "        #deepsupervision\n",
    "        if self.training:\n",
    "            # Return multiple scales during training\n",
    "            return [\n",
    "                self.ds1(d1), # Full resolution\n",
    "                self.ds2(d2), # 1/2 resolution\n",
    "                self.ds3(d3), # 1/4 resolution\n",
    "                self.ds4(d4)  # 1/8 resolution\n",
    "            ]\n",
    "        else:\n",
    "            return self.ds1(d1)\n",
    "\n",
    "#model = ResUNet(pretrained=True).to(CFG.device)\n",
    "# 1. instance first\n",
    "model = ResUNet(n_classes=1, pretrained=True) \n",
    "\n",
    "# 2.  multi-GPU\n",
    "if torch.cuda.device_count() > 1:\n",
    "    print(f\"Wrapping model with DataParallel on {torch.cuda.device_count()} GPUs\")\n",
    "    model = nn.DataParallel(model)\n",
    "\n",
    "# 3.  send to the device\n",
    "model = model.to(CFG.device)\n",
    "\n",
