99Z","iopub.execute_input":"2026-04-28T19:17:33.505506Z","iopub.status.idle":"2026-04-28T19:17:33.515716Z","shell.execute_reply.started":"2026-04-28T19:17:33.505444Z","shell.execute_reply":"2026-04-28T19:17:33.514942Z"}},"outputs":[{"name":"stdout","text":"Device : cuda\n","output_type":"stream"}],"execution_count":34},{"cell_type":"code","source":"# ── Cell 4: Load & explore data ───────────────────────────────────────────────\ndef get_pairs(data_dir):\n    imgs = sorted(glob.glob(os.path.join(data_dir,'**','*.tif'), recursive=True))\n    imgs = [p for p in imgs if '_mask' not in p]\n    pairs = []\n    for p in imgs:\n        m = p.replace('.tif','_mask.tif')\n        if os.path.exists(m): pairs.append((p, m))\n    return pairs\n\nall_pairs = get_pairs(CFG.data_dir)\nprint(f'Total image-mask pairs : {len(all_pairs)}')\n\n# Count positives (slices that actually contain tumour)\npos = 0\nfor _, m in all_pairs:\n    if np.array(Image.open(m)).max() > 0: pos += 1\nprint(f'Slices with tumour     : {pos} ({100*pos/len(all_pairs):.1f}%)')\nprint(f'Slices without tumour  : {len(all_pairs)-pos} ({100*(len(all_pairs)-pos)/len(all_pairs):.1f}%)')\n\n# Plot class balance\nfig, ax = plt.subplots(figsize=(5,3))\nax.bar(['With Tumour','Without Tumour'], [pos, len(all_pairs)-pos],\n       color=['#e74c3c','#3498db'], edgecolor='white', linewidth=1.5)\nax.set_title('Slice-level Class Distribution', fontweight='bold')\nax.set_ylabel('Count')\nfor p in ax.patches:\n    ax.annotate(f'{int(p.get_height())}', (p.get_x()+p.get_width()/2, p.get_height()),\n                ha='center', va='bottom', fontweight='bold')\nplt.tight_layout(); plt.show()","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":359},"id":"WnZ5pMQw_05_","outputId":"a88a4f02-715d-470e-d2dc-d4ff8ee52032","trusted":true,"execution":{"iopub.status.busy":"2026-04-28T18:43:24.801809Z","iopub.execute_input":"2026-04-28T18:43:24.802512Z","iopub.status.idle":"2026-04-28T18:44:06.403521Z","shell.execute_reply.started":"2026-04-28T18:43:24.802481Z","shell.execute_reply":"2026-04-28T18:44:06.402838Z"}},"outputs":[{"name":"stdout","text":"Total image-mask pairs : 3929\nSlices with tumour     : 1373 (34.9%)\nSlices without tumour  : 2556 (65.1%)\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 500x300 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":8},{"cell_type":"code","source":"# ── Cell 5: Visualise raw samples ─────────────────────────────────────────────\n# Show 5 slices WITH tumour + overlay\npositive_pairs = [(i,m) for i,m in all_pairs if np.array(Image.open(m)).max()>0]\nsamples = random.sample(positive_pairs, 5)\n\nfig, axes = plt.subplots(5, 3, figsize=(11, 17))\nfig.suptitle('Raw Data Exploration  |  MRI — Mask — Overlay', fontsize=14, fontweight='bold', y=1.01)\n\nfor row, (ip, mp) in enumerate(samples):\n    img  = np.array(Image.open(ip).convert('RGB'))\n    mask = np.array(Image.open(mp).convert('L'))\n\n    axes[row,0].imshow(img);                    axes[row,0].set_title('MRI', fontsize=9)\n    axes[row,1].imshow(mask, cmap='hot');       axes[row,1].set_title('Mask', fontsize=9)\n\n    # Overlay: blend mask in red over greyscale MRI\n    grey = np.stack([img.mean(-1)]*3, axis=-1).astype(np.uint8)\n    overlay = grey.copy()\n    overlay[mask>127] = [220, 50, 50]\n    axes[row,2].imshow(overlay);                axes[row,2].set_title('Overlay', fontsize=9)\n\n    for ax in axes[row]: ax.axis('off')\n\nplt.tight_layout(); plt.show()","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"oi9Df2-x_05_","outputId":"e3cde928-9c37-45e6-f71f-b0260b271565","trusted":true,"execution":{"iopub.status.busy":"2026-04-28T18:44:06.405019Z","iopub.execute_input":"2026-04-28T18:44:06.405461Z","iopub.status.idle":"2026-04-28T18:44:12.067587Z","shell.execute_reply.started":"2026-04-28T18:44:06.405431Z","shell.execute_reply":"2026-04-28T18:44:12.066738Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1100x1700 with 15 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":9},{"cell_type":"code","source":"# ── Cell 6: Dataset class + augmentation preview ──────────────────────────────\nclass BrainMRIDataset(Dataset):\n    def __init__(self, pairs, img_size=256, augment=False):\n        self.pairs   = pairs\n        self.size    = img_size\n        self.augment = augment\n\n    def __len__(self): return len(self.pairs)\n\n    def __getitem__(self, idx):\n        ip, mp = self.pairs[idx]\n        img  = Image.open(ip).convert('RGB').resize((self.size,self.size), Image.BILINEAR)\n        mask = Image.open(mp).convert('L').resize((self.size,self.size), Image.NEAREST)\n\n        if self.augment:\n            if random.random()>0.5: img,mask = TF.hflip(img), TF.hflip(mask)\n            if random.random()>0.5: img,mask = TF.vflip(img), TF.vflip(mask)\n            angle = random.uniform(-30,30)\n            img,mask = TF.rotate(img,angle), TF.rotate(mask,angle)\n            if random.random()>0.5:\n                img = TF.adjust_brightness(img, random.uniform(0.8,1.2))\n                img = TF.adjust_contrast(img,   random.uniform(0.8,1.2))\n\n        img  = TF.to_tensor(img)                                    # [3,H,W]\n        mask = torch.from_numpy(np.array(mask)).float()\n        mask = (mask>127).float().unsqueeze(0)                      # [1,H,W]\n        return img, mask\n\n# Preview augmentations on one positive sample\naug_ds = BrainMRIDataset(positive_pairs[:1], augment=True)\nfig, axes = plt.subplots(2, 5, figsize=(14,6))\nfig.suptitle('Augmentation Preview (same slice, 5 random draws)', fontweight='bold')\nfor col in range(5):\n    im, mk = aug_ds[0]\n    axes[0,col].imshow(im.permute(1,2,0).numpy())\n    axes[0,col].set_title(f'Aug {col+1}'); axes[0,col].axis('off')\n    axes[1,col].imshow(mk.squeeze().numpy(), cmap='hot')\n    axes[1,col].axis('off')\naxes[0,0].set_ylabel('Image', fontweight='bold')\naxes[1,0].set_ylabel('Mask',  fontweight='bold')\nplt.tight_layout(); plt.show()","metadata":{"id":"hrJ6kJTN_06A","colab":{"base_uri":"https://localhost:8080/","height":392},"outputId":"5931787b-bd95-4d5e-8257-1005e92d5424","trusted":true,"execution":{"iopub.status.busy":"2026-04-28T18:46:28.714744Z","iopub.execute_input":"2026-04-28T18:46:28.715523Z","iopub.status.idle":"2026-04-28T18:46:29.467415Z","shell.execute_reply.started":"2026-04-28T18:46:28.715492Z","shell.execute_reply":"2026-04-28T18:46:29.466358Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1400x600 with 10 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":10},{"cell_type":"code","source":"# ── Cell 7: Train / Val / Test split + DataLoaders ────────────────────────────\ntrain_pairs, temp  = train_test_split(all_pairs, test_size=CFG.val_split+CFG.test_split, random_state=CFG.seed)\nval_pairs,  test_pairs = train_test_split(temp,\n    test_size=CFG.test_split/(CFG.val_split+CFG.test_split), random_state=CFG.seed)\n\nprint(f'Train : {len(train_pairs)} | Val : {len(val_pairs)} | Test : {len(test_pairs)}')\n\ntrain_ds = BrainMRIDataset(train_pairs, CFG.img_size, augment=True)\nval_ds   = BrainMRIDataset(val_pairs,   CFG.img_size, augment=False)\ntest_ds  = BrainMRIDataset(test_pairs,  CFG.img_size, augment=False)\n\nnw = 2\ntrain_loader = DataLoader(train_ds, CFG.batch_size, shuffle=True,  num_workers=nw, pin_memory=True)\nval_loader   = DataLoader(val_ds,   CFG.batch_size, shuffle=False, num_workers=nw, pin_memory=True)\ntest_loader  = DataLoader(test_ds,  CFG.batch_size, shuffle=False, num_workers=nw, pin_memory=True)\n\nimgs, masks = next(iter(train_loader))\nprint(f'Batch — images: {tuple(imgs.shape)}  masks: {tuple(masks.shape)}')","metadata":{"id":"GI6qkGjK_06A","colab":{"base_uri":"https://localhost:8080/"},"outputId":"4a475cfd-fe20-4725-ddb4-0d015d459c52","trusted":true,"execution":{"iopub.status.busy":"2026-04-28T18:46:35.239094Z","iopub.execute_input":"2026-04-28T18:46:35.240085Z","iopub.status.idle":"2026-04-28T18:46:36.056649Z","shell.execute_reply.started":"2026-04-28T18:46:35.240054Z","shell.execute_reply":"2026-04-28T18:46:36.055584Z"}},"outputs":[{"name":"stdout","text":"Train : 2946 | Val : 589 | Test : 394\nBatch — images: (16, 3, 256, 256)  masks: (16, 1, 256, 256)\n","output_type":"stream"}],"execution_count":11},{"cell_type":"code","source":"# ── Cell 8: ResNet-UNet architecture ─────────────────────────────────────────\n#\n# Encoder : ResNet-34 pretrained on ImageNet\n#   skip connections taken from 4 ResNet stages:\n#     layer1 → 64ch  (H/4)\n#     layer2 → 128ch (H/8)\n#     layer3 → 256ch (H/16)\n#     layer4 → 512ch (H/32)\n# Bottleneck: after layer4, one extra DoubleConv (1024ch, H/32)\n# Decoder : 4× upsampling blocks that concatenate encoder skips\n#\n\nclass DecoderBlock(nn.Module):\n    \"\"\"Upsample → concat skip → DoubleConv.\"\"\"\n    def __init__(self, in_ch, skip_ch, out_ch):\n        super().__init__()\n        self.up = nn.ConvTranspose2d(in_ch, in_ch // 2, kernel_size=2, stride=2)\n        self.conv = nn.Sequential(\n            nn.Conv2d(in_ch // 2 + skip_ch, out_ch, 3, padding=1, bias=False),\n            nn.BatchNorm2d(out_ch), nn.ReLU(inplace=True),\n            nn.Conv2d(out_ch, out_ch, 3, padding=1, bias=False),\n            nn.BatchNorm2d(out_ch), nn.ReLU(inplace=True),\n        )\n\n    def forward(self, x, skip):\n        x = self.up(x)\n        # If the upsampled x is not the same size as skip, adjust skip\n        # This ensures the decoder path maintains or increases resolution\n        if x.shape[2:] != skip.shape[2:]:\n            skip = torch.nn.functional.interpolate(skip, size=x.shape[2:], mode='bilinear', align_corners=False)\n        x = torch.cat([x, skip], dim=1)\n        return self.conv(x)\n\n\nclass ResUNet(nn.Module):\n    \"\"\"\n    U-Net with a pretrained ResNet-34 encoder.\n    Input : (B, 3, H, W)  — RGB, any multiple of 32\n    Output: (B, 1, H, W)  — raw logits\n    \"\"\"\n    def __init__(self, n_classes=1, pretrained=True):\n        super().__init__()\n        self.n_classes = n_classes\n        # ── Encoder ──────────────────────────────────────────────────────────\n        backbone = models.resnet34(weights='IMAGENET1K_V1' if pretrained else None)\n\n        # stem: Conv + BN + ReLU  (stride 2 → H/2, 64ch)\n        self.enc0 = nn.Sequential(\n            backbone.conv1, backbone.bn1, backbone.relu\n        )  # out: 64ch, H/2\n        self.pool  = backbone.maxpool          # H/4\n        self.enc1  = backbone.layer1           # 64ch,  H/4\n        self.enc2  = backbone.layer2           # 128ch, H/8\n        self.enc3  = backbone.layer3           # 256ch, H/16\n        self.enc4  = backbone.layer4           # 512ch, H/32\n\n        # ── Bottleneck ───────────────────────────────────────────────────────\n        self.bottleneck = nn.Sequential(\n            nn.Conv2d(512, 1024, 3, padding=1, bias=False),\n            nn.BatchNorm2d(1024), nn.ReLU(inplace=True),\n            nn.Conv2d(1024, 1024, 3, padding=1, bias=False),\n            nn.BatchNorm2d(1024), nn.ReLU(inplace=True),\n        )  # 1024ch, H/32\n\n        # ── Decoder ──────────────────────────────────────────────────────────\n        # Each DecoderBlock(in_ch, skip_ch, out_ch)\n        self.dec4 = DecoderBlock(1024, 512, 512)   # H/16\n        self.dec3 = DecoderBlock(512,  256, 256)   # H/8\n        self.dec2 = DecoderBlock(256,  128, 128)   # H/4\n        self.dec1 = DecoderBlock(128,   64,  64)   # H/2  (skip from enc1)\n        # Final up to full resolution (no skip — use enc0 stem features)\n        self.dec0 = DecoderBlock(64,    64,  32)   # H\n\n        self.final = nn.Conv2d(32, 1, kernel_size=1)\n\n        #deepsupervision\n        self.ds4 = nn.Conv2d(256, self.n_classes, kernel_size=1) # High-level\n        self.ds3 = nn.Conv2d(128, self.n_classes, kernel_size=1)\n        self.ds2 = nn.Conv2d(64, self.n_classes, kernel_size=1)\n        self.ds1 = nn.Conv2d(32, self.n_classes, kernel_size=1) # Final output\n\n    def forward(self, x):\n        # Encoder\n        e0 = self.enc0(x)          # 64ch,  H/2\n        e1 = self.enc1(self.pool(e0))  # 64ch,  H/4\n        e2 = self.enc2(e1)         # 128ch, H/8\n        e3 = self.enc3(e2)         # 256ch, H/16\n        e4 = self.enc4(e3)         # 512ch, H/32\n\n        # Bottleneck\n        b  = self.bottleneck(e4)   # 1024ch, H/32\n\n        # Decoder\n        d4 = self.dec4(b,  e4)     # 512ch, H/16\n        d3 = self.dec3(d4, e3)     # 256ch, H/8\n        d2 = self.dec2(d3, e2)     # 128ch, H/4\n        d1 = self.dec1(d2, e1)     # 64ch,  H/2\n        d0 = self.dec0(d1, e0)     # 32ch,  H\n\n        return self.final(d0)      # 1ch,   H\n\n        #deepsupervision\n        if self.training:\n            # Return multiple scales during training\n            return [\n                self.ds1(d1), # Full resolution\n                self.ds2(d2), # 1/2 resolution\n                self.ds3(d3), # 1/4 resolution\n                self.ds4(d4)  # 1/8 resolution\n            ]\n        else:\n            return self.ds1(d1)\n\n#model = ResUNet(pretrained=True).to(CFG.device)\n# 1. instance first\nmodel = ResUNet(n_classes=1, pretrained=True) \n\n# 2.  multi-GPU\nif torch.cuda.device_count() > 1:\n    print(f\"Wrapping model with DataParallel on {torch.cuda.device_count()} GPUs\")\n    model = nn.DataParallel(model)\n\n# 3.  send to the device\nmodel = model.to(CFG.device)\n\n\n\ntotal_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\nprint(f'ResNet-UNet parameters: {total_params/1e6:.2f}M')\n\n# Quick shape check\nwith torch.no_grad():\n    dummy = torch.zeros(1,3,256,256).to(CFG.device)\n    out   = model(dummy)\n    print(f'Input → Output: {tuple(dummy.shape)} → {tuple(out.shape)}  ')\n","metadata":{"id":"YpEgsbkB_06A","colab":{"base_uri":"https://localhost:8080/"},"outputId":"c7956548-b5d7-44fe-af69-84d4410a137e","trusted":true,"execution":{"iopub.status.busy":"2026-04-28T18:47:14.966485Z","iopub.execute_input":"2026-04-28T18:47:14.967297Z","iopub.status.idle":"2026-04-28T18:47:15.604479Z","shell.execute_reply.started":"2026-04-28T18:47:14.967267Z","shell.execute_reply":"2026-04-28T18:47:15.603434Z"}},"outputs":[{"name":"stdout","text":"Wrapping model with DataParallel on 2 GPUs\nResNet-UNet parameters: 47.68M\nInput → Output: (1, 3, 256, 256) → (1, 1, 256, 256)  \n","output_type":"stream"}],"execution_count":14},{"cell_type":"code","source":"# ── Cell 9: Loss, metrics & optimizer ────────────────────────────────────────\nclass DiceBCELoss(nn.Module):\n    def __init__(self, smooth=1e-6):\n        super().__init__()\n        self.bce    = nn.BCEWithLogitsLoss()\n        self.smooth = smooth\n\n    def forward(self, logits, targets):\n        bce   = self.bce(logits, targets)\n        prob  = torch.sigmoid(logits)\n        inter = (prob * targets).sum(dim=(2,3))\n        dice  = 1 - (2*inter + self.smooth) / (\n            prob.sum(dim=(2,3)) + targets.sum(dim=(2,3)) + self.smooth)\n        return bce + dice.mean()\n\n\ndef dice_score(logits, targets, thr=0.5, smooth=1e-6):\n    p = (torch.sigmoid(logits) > thr).float()\n    i = (p * targets).sum(dim=(2,3))\n    return ((2*i+smooth)/(p.sum(dim=(2,3))+targets.sum(dim=(2,3))+smooth)).mean().item()\n\ndef iou_score(logits, targets, thr=0.5, smooth=1e-6):\n    p = (torch.sigmoid(logits) > thr).float()\n    i = (p * targets).sum(dim=(2,3))\n    u = (p + targets - p*targets).sum(dim=(2,3))\n    return ((i+smooth)/(u+smooth)).mean().item()\n\n\ncriterion = DiceBCELoss()\n\nif isinstance(model, nn.DataParallel):\n    base_model = model.module\nelse:\n    base_model = model\n\n# Differential LR: encoder (pretrained) gets 10× smaller lr\nencoder_params = list(base_model.enc0.parameters()) + list(base_model.enc1.parameters()) + \\\n                 list(base_model.enc2.parameters()) + list(base_model.enc3.parameters()) + \\\n                 list(base_model.enc4.parameters())\ndecoder_params = [p for p in model.parameters()\n                  if not any(p is ep for ep in encoder_params)]\n\noptimizer = optim.Adam([\n    {'params': encoder_params, 'lr': CFG.lr / 10},  # pretrained weights\n    {'params': decoder_params, 'lr': CFG.lr},        # new decoder weights\n], lr=CFG.lr)\n\nscheduler = optim.lr_scheduler.ReduceLROnPlateau(\n    optimizer, mode='max', patience=5, factor=0.5\n)\n\nprint('Loss, metrics, optimizer ready ')\n","metadata":{"id":"Vms2XjMk_06B","colab":{"base_uri":"https://localhost:8080/"},"outputId":"91a8876c-14cc-4706-c838-6a95e40737ef","trusted":true,"execution":{"iopub.status.busy":"2026-04-28T18:51:53.220990Z","iopub.execute_input":"2026-04-28T18:51:53.221895Z","iopub.status.idle":"2026-04-28T18:51:53.234723Z","shell.execute_reply.started":"2026-04-28T18:51:53.221863Z","shell.execute_reply":"2026-04-28T18:51:53.234017Z"}},"outputs":[{"name":"stdout","text":"Loss, metrics, optimizer ready \n","output_type":"stream"}],"execution_count":24},{"cell_type":"code","source":"# ── Cell 10: Checkpoint helpers ───────────────────────────────\n\ndef save_checkpoint(epoch, model, optimizer, scheduler, history, best_dice, path):\n    \"\"\"Save full training state — resume from here later.\"\"\"\n    os.makedirs(os.path.dirname(path), exist_ok=True)\n    torch.save({\n        'epoch':      epoch,\n        'model':      model.state_dict(),\n        'optimizer':  optimizer.state_dict(),\n        'scheduler':  scheduler.state_dict(),\n        'history':    history,\n        'best_dice':  best_dice,\n    }, path)\n    print(f'  [ckpt] Checkpoint saved → {path}')\n\n\ndef load_checkpoint(path, model, optimizer, scheduler):\n    \"\"\"\n    Load a full checkpoint.\n    Returns (start_epoch, history, best_dice) so training continues\n    from exactly where it stopped.\n    \"\"\"\n    ckpt = torch.load(path, map_location=CFG.device)\n    model.load_state_dict(ckpt['model'])\n    optimizer.load_state_dict(ckpt['optimizer'])\n    scheduler